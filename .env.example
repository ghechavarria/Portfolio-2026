# LinkedIn profile photo sync (local script + Netlify scheduled function)
# Copy to .env and fill in as needed. Never commit .env.

# Override LinkedIn profile URL (default: site.linkedin in portfolioData.js)
# LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/your-handle

# Direct image URL fallback when LinkedIn blocks page scraping
# LINKEDIN_IMAGE_URL=https://media.licdn.com/dms/image/...

# Local dev: leave unset to use public/assets/profile.jpg from npm run sync:linkedin
# Netlify sets this in netlify.toml for production builds
# VITE_PROFILE_PHOTO_URL=/.netlify/functions/profile-photo
